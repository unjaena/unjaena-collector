# =============================================================================
# Forensic Collector - Git Ignore
# =============================================================================

# Sensitive config files (API keys, server URLs, etc.)
config.json
config.local.json
config.development.json
config.production.json
config.staging.json
*.secret
*.credentials

# Collected artifacts (large files, personal data)
collected_artifacts/
artifacts/
output/
extracted/
temp/
tmp/

# Log files
logs/
*.log

# Forensic image files (large)
*.E01
*.e01
*.Ex01
*.L01
*.raw
*.dd
*.img
*.dmg
*.iso

# Mobile backups (personal data)
**/MobileSync/
**/Backup/
*.ab
*.ab.bak

# iOS backup files
Manifest.db
Manifest.plist
Info.plist
Status.plist

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv/

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Test outputs
test_output/
test_artifacts/
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Documentation build
docs/_build/

# Chain of custody logs
custody_log*.json
chain_of_custody/

# Temporary files
*.tmp
*.bak
*.backup
*.old

# Database files (may contain evidence)
*.db
*.sqlite
*.sqlite3

# Encryption keys (NEVER commit)
*.key
*.pem
*.crt
*.cer
private/
keys/

# Environment files (never commit secrets)
.env
.env.*
!.env.example

# =============================================================================
# External Tools (downloaded at build time)
# =============================================================================

# libimobiledevice binaries (LGPL-2.1, downloaded via download_libimobiledevice.py)
tools/libimobiledevice/*.exe
tools/libimobiledevice/*.dll
tools/libimobiledevice/LICENSE
!tools/libimobiledevice/.gitkeep

# Downloaded archives
tools/*.zip
tools/*.tar.gz

# =============================================================================
# Third-party binaries (downloaded separately, not redistributable)
# =============================================================================

# Memory acquisition tool (Apache 2.0 — https://github.com/Velocidex/WinPmem)
resources/winpmem_mini_x64.exe

# USB library binary (install via pip: libusb1)
resources/libusb-1.0.dll

# Android APK files (copyrighted third-party apps, not redistributable)
resources/downgrade_apks/*.apk
!resources/downgrade_apks/README.txt

# NUL placeholder
resources/downgrade_apks/NUL
