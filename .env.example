# Collector Environment Variables
# Optional values for source-based or scripted runs.
# GUI releases use the first-run server setup dialog and local user config.

# Upload service URL used by src/core/secure_upload.py examples.
FORENSIC_SERVER_URL=https://your-server.com

# For local development only.
# Requires COLLECTOR_DEV_MODE or FORENSIC_DEV_MODE in the relevant entry point.
# FORENSIC_SERVER_URL=http://127.0.0.1:8000
